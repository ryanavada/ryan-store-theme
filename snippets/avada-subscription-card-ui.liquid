                      data-plan-id="{{ plan.sellingPlanId }}"
                      data-discount-enabled="{{ plan.enabledDiscount }}"
                      data-discount-type="{{ plan.discountType }}"
                      data-discount-value="{{ plan.discountValue }}"
                      data-enabled-change-discount="{{ plan.enabledChangeDiscount }}"
                      data-discount-value-changed="{{ plan.discountValueChanged }}"
                      data-discount-tiers-desc="{{ discount_tiers_desc | escape }}"
