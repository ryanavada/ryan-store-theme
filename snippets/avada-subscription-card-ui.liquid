<script>
  (function() {
    const wrapper = document.currentScript.previousElementSibling;
    
    // Get product data
    const productPrice = {{ product_price | json }};
    
    // Function to get or create selling plan inputs for all cart forms
    function updateSellingPlanInputs(value) {
      const formEls = document.querySelectorAll('form[action*="/cart/add"]');
      formEls.forEach(el => {
        let sellingPlanInput = el.querySelector('input[name="selling_plan"]');
        
        if (!sellingPlanInput) {
          sellingPlanInput = document.createElement('input');
          sellingPlanInput.type = 'hidden';
          sellingPlanInput.name = 'selling_plan';
          el.appendChild(sellingPlanInput);
        }
        
        sellingPlanInput.value = value || '';
      });
    }
    
    // Purchase type selection
    const purchaseOptions = wrapper.querySelectorAll('.subscription-card__option');
    const frequencySection = wrapper.querySelector('.subscription-card__frequency');
    const priceOriginal = wrapper.querySelector('.subscription-card__price-original');
    const priceDiscounted = wrapper.querySelector('.subscription-card__price-discounted');
    
    // Frequency selection
    const frequencyPills = wrapper.querySelectorAll('.subscription-card__frequency-pill');
    const frequencyOptions = wrapper.querySelector('.subscription-card__frequency-options');
    
    // Function to handle last row filling - refactored to work with any section
    function adjustLastRowLayoutForSection(pills, options) {
      if (!options || pills.length === 0) return;
      
      // Remove any previous last-row classes
      pills.forEach(function(pill) {
        pill.classList.remove('subscription-card__frequency-pill--last-row-2', 'subscription-card__frequency-pill--last-row-1');
      });
      
      const totalItems = pills.length;
      const itemsPerRow = 3;
      const lastRowCount = totalItems % itemsPerRow;
      
      // Only adjust if last row is incomplete
      if (lastRowCount === 0) return;
      
      const lastRowStartIndex = totalItems - lastRowCount;
      
      if (lastRowCount === 2) {
        options.style.display = 'flex';
        options.style.flexWrap = 'wrap';
        
        pills.forEach(function(pill, index) {
          if (index < lastRowStartIndex) {
            pill.style.flex = '0 0 calc((100% - 24px) / 3)';
          } else {
            pill.style.flex = '0 0 calc((100% - 12px) / 2)';
            pill.classList.add('subscription-card__frequency-pill--last-row-2');
          }
        });
      } else if (lastRowCount === 1) {
        options.style.display = 'flex';
        options.style.flexWrap = 'wrap';
        
        pills.forEach(function(pill, index) {
          if (index < lastRowStartIndex) {
            pill.style.flex = '0 0 calc((100% - 24px) / 3)';
          } else {
            pill.style.flex = '0 0 100%';
            pill.classList.add('subscription-card__frequency-pill--last-row-1');
          }
        });
      }
    }
    
    // Call on load for all frequency sections
    const allFrequencyOptions = wrapper.querySelectorAll('.subscription-card__frequency-options');
    allFrequencyOptions.forEach(function(options) {
      const pills = options.querySelectorAll('.subscription-card__frequency-pill');
      adjustLastRowLayoutForSection(pills, options);
    });
    
    // Initialize discount benefit for default selected plan on page load
    const initialSelectedCard = wrapper.querySelector('.subscription-card__option--selected');
    if (initialSelectedCard) {
      const initialSelectedPill = initialSelectedCard.querySelector('.subscription-card__frequency-pill--selected');
      if (initialSelectedPill) {
        const discountEnabled = initialSelectedPill.getAttribute('data-discount-enabled');
        const discountType = initialSelectedPill.getAttribute('data-discount-type');
        const discountValue = parseFloat(initialSelectedPill.getAttribute('data-discount-value'));
        const enabledChangeDiscount = initialSelectedPill.getAttribute('data-enabled-change-discount');
        const discountValueChanged = initialSelectedPill.getAttribute('data-discount-value-changed');
        const planId = initialSelectedPill.getAttribute('data-plan-id');
        
        // Set initial selling plan if it exists
        if (planId) {
          updateSellingPlanInputs(planId);
        }
        
        // Calculate discounted price
        let discountedPrice = productPrice;
        if (discountEnabled === 'true' && discountType === 'percentage') {
          discountedPrice = productPrice - (productPrice * discountValue / 100);
        } else if (discountEnabled === 'true' && discountType === 'fixed') {
          discountedPrice = productPrice - (discountValue * 100);
        }
        
        // Show/hide original price
        const initialPriceOriginal = initialSelectedCard.querySelector('.subscription-card__price-original');
        if (initialPriceOriginal) {
          if (discountEnabled === 'true' && discountedPrice < productPrice) {
            initialPriceOriginal.style.display = 'inline';
          } else {
            initialPriceOriginal.style.display = 'none';
          }
        }
        
        updateDiscountBenefit(initialSelectedCard, discountEnabled, discountType, discountValue, enabledChangeDiscount, discountValueChanged);
      }
    } else {
      // Clear selling plan for one-time purchase
      updateSellingPlanInputs('');
    }
    
    purchaseOptions.forEach(function(option) {
      option.addEventListener('click', function() {
        // Remove selected state from all options
        purchaseOptions.forEach(function(opt) {
          opt.classList.remove('subscription-card__option--selected');
          const radio = opt.querySelector('.subscription-card__radio-input');
          if (radio) radio.checked = false;
        });
        
        // Add selected state to clicked option
        option.classList.add('subscription-card__option--selected');
        const radio = option.querySelector('.subscription-card__radio-input');
        if (radio) radio.checked = true;
        
        // Show/hide frequency section based on selection
        const purchaseType = option.getAttribute('data-purchase-type');
        
        // Hide all frequency sections first
        const allFrequencySections = wrapper.querySelectorAll('.subscription-card__frequency');
        allFrequencySections.forEach(function(section) {
          section.style.display = 'none';
        });
        
        // Show the appropriate frequency section
        if (purchaseType === 'autoship' || purchaseType === 'prepaid') {
          const currentFrequencySection = option.querySelector('.subscription-card__frequency');
          if (currentFrequencySection) {
            currentFrequencySection.style.display = 'flex';
            
            // Update selling plan input with selected plan from this section
            const selectedPill = currentFrequencySection.querySelector('.subscription-card__frequency-pill--selected');
            if (selectedPill) {
              const planId = selectedPill.getAttribute('data-plan-id');
              if (planId) {
                updateSellingPlanInputs(planId);
              }
            }
            
            // Re-adjust layout when showing
            setTimeout(function() {
              const pills = currentFrequencySection.querySelectorAll('.subscription-card__frequency-pill');
              const options = currentFrequencySection.querySelector('.subscription-card__frequency-options');
              adjustLastRowLayoutForSection(pills, options);
            }, 10);
          }
        } else if (purchaseType === 'one-time') {
          // Clear selling plan for one-time purchase
          updateSellingPlanInputs('');
        }
        
        // Update pricing display for the selected option
        const optionPriceDiscounted = option.querySelector('.subscription-card__price-discounted');
        const selectedPill = option.querySelector('.subscription-card__frequency-pill--selected');
        
        // Hide discount benefit for one-time purchase, show for subscription if plan selected
        const allDiscountBenefits = wrapper.querySelectorAll('.subscription-card__benefit--discount');
        allDiscountBenefits.forEach(function(benefit) {
          benefit.style.display = 'none';
        });
        
        if (selectedPill && optionPriceDiscounted) {
          const discountEnabled = selectedPill.getAttribute('data-discount-enabled');
          const discountType = selectedPill.getAttribute('data-discount-type');
          const discountValue = parseFloat(selectedPill.getAttribute('data-discount-value'));
          const enabledChangeDiscount = selectedPill.getAttribute('data-enabled-change-discount');
          const discountValueChanged = selectedPill.getAttribute('data-discount-value-changed');
          
          let discountedPrice = productPrice;
          
          if (discountEnabled === 'true' && discountType === 'percentage') {
            discountedPrice = productPrice - (productPrice * discountValue / 100);
          } else if (discountEnabled === 'true' && discountType === 'fixed') {
            discountedPrice = productPrice - (discountValue * 100);
          }
          
          optionPriceDiscounted.textContent = formatMoney(discountedPrice, {{ shop.money_format | json }});
          
          // Show/hide original price based on discount
          const optionPriceOriginal = option.querySelector('.subscription-card__price-original');
          if (optionPriceOriginal) {
            if (discountEnabled === 'true' && discountedPrice < productPrice) {
              optionPriceOriginal.style.display = 'inline';
            } else {
              optionPriceOriginal.style.display = 'none';
            }
          }
          
          // Update discount benefit for the selected card
          updateDiscountBenefit(option, discountEnabled, discountType, discountValue, enabledChangeDiscount, discountValueChanged);
        }
      });
    });
    
    // Function to update discount benefit display
    function updateDiscountBenefit(card, discountEnabled, discountType, discountValue, enabledChangeDiscount, discountValueChanged) {
      const discountBenefit = card.querySelector('.subscription-card__benefit--discount');
      const benefitText = discountBenefit.querySelector('.subscription-card__benefit-text');
      
      // Hide if discount is not enabled or has no value
      if (discountEnabled !== 'true' || !discountType || discountValue === 0 || discountValue === null) {
        discountBenefit.style.display = 'none';
        return;
      }
      
      // Format text
      let text = '';
      if (discountType === 'percentage') {
        text = '{{ save_from_text }} ' + discountValue + '%';
      } else if (discountType === 'fixed') {
        text = '{{ save_from_text }} ' + formatMoney(discountValue, {{ shop.money_format | json }});
      }
      
      benefitText.textContent = text;
      discountBenefit.style.display = 'flex';
    }
    
    // Handle frequency pill selection for both autoship and prepaid
    const allFrequencyPills = wrapper.querySelectorAll('.subscription-card__frequency-pill');
    allFrequencyPills.forEach(function(pill) {
      pill.addEventListener('click', function() {
        // Get the parent frequency options container to only deselect pills in the same group
        const parentOptions = pill.closest('.subscription-card__frequency-options');
        const paymentType = parentOptions.getAttribute('data-payment-type');
        const parentCard = pill.closest('.subscription-card__option');
        
        // Deselect all pills in the same payment type group
        const siblingPills = parentOptions.querySelectorAll('.subscription-card__frequency-pill');
        siblingPills.forEach(function(p) {
          p.classList.remove('subscription-card__frequency-pill--selected');
        });
        
        // Select clicked pill
        pill.classList.add('subscription-card__frequency-pill--selected');
        
        // Update pricing based on selected plan
        const discountEnabled = pill.getAttribute('data-discount-enabled');
        const discountType = pill.getAttribute('data-discount-type');
        const discountValue = parseFloat(pill.getAttribute('data-discount-value'));
        const enabledChangeDiscount = pill.getAttribute('data-enabled-change-discount');
        const discountValueChanged = pill.getAttribute('data-discount-value-changed');
        
        let discountedPrice = productPrice;
        
        if (discountEnabled === 'true' && discountType === 'percentage') {
          discountedPrice = productPrice - (productPrice * discountValue / 100);
        } else if (discountEnabled === 'true' && discountType === 'fixed') {
          discountedPrice = productPrice - (discountValue * 100);
        }
        
        // Update displayed prices in the current card
        const cardPriceDiscounted = parentCard.querySelector('.subscription-card__price-discounted');
        const cardPriceOriginal = parentCard.querySelector('.subscription-card__price-original');
        
        if (cardPriceDiscounted) {
          cardPriceDiscounted.textContent = formatMoney(discountedPrice, {{ shop.money_format | json }});
        }
        
        // Show/hide original price based on discount
        if (cardPriceOriginal) {
          if (discountEnabled === 'true' && discountedPrice < productPrice) {
            cardPriceOriginal.style.display = 'inline';
          } else {
            cardPriceOriginal.style.display = 'none';
          }
        }
        
        // Update discount benefit text
        updateDiscountBenefit(parentCard, discountEnabled, discountType, discountValue, enabledChangeDiscount, discountValueChanged);
        
        // Update selling plan input
        const planId = pill.getAttribute('data-plan-id');
        if (planId) {
          updateSellingPlanInputs(planId);
        }
      });
    });
    
    // Toggle layout functionality
    const toggleButtons = wrapper.querySelectorAll('.subscription-card__toggle-button');
    const toggleOptions = wrapper.querySelectorAll('.subscription-card__shared-content .subscription-card__option');
    
    toggleButtons.forEach(function(button) {
      button.addEventListener('click', function() {
        const purchaseType = this.getAttribute('data-purchase-type');
        
        // Update toggle button selection
        toggleButtons.forEach(function(btn) {
          btn.classList.remove('subscription-card__toggle-button--selected');
        });
        this.classList.add('subscription-card__toggle-button--selected');
        
        // Update content visibility
        toggleOptions.forEach(function(option) {
          option.classList.remove('subscription-card__option--active');
        });
        
        const activeOption = wrapper.querySelector('.subscription-card__shared-content .subscription-card__option[data-purchase-type="' + purchaseType + '"]');
        if (activeOption) {
          activeOption.classList.add('subscription-card__option--active');
          
          // Trigger the radio input selection
          const radioInput = activeOption.querySelector('.subscription-card__radio-input');
          if (radioInput) {
            radioInput.checked = true;
            radioInput.dispatchEvent(new Event('change', { bubbles: true }));
          }
        }
      });
    });
    
  })();
</script>