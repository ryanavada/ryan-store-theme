                      <div class="subscription-card__frequency-weeks">{{ frequency_text }}</div>
                      {%- if discount_text != blank -%}
                        <div class="subscription-card__frequency-save">{{ discount_text }}</div>
                      {%- endif -%}
                    </div>
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  {%- else -%}
